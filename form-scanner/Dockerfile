# Node 20 + Chrome для Puppeteer
FROM node:20-slim

# Устанавливаем Chrome и зависимости
RUN apt-get update && apt-get install -y \
    chromium \
    fonts-liberation \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

# Говорим Puppeteer использовать системный Chrome вместо скачивания своего
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

WORKDIR /app

COPY package*.json ./
RUN npm install --production

COPY . .

# Создаём папку для БД (будет смонтирован как Volume в Railway)
RUN mkdir -p /data

EXPOSE 3000

CMD ["node", "server.js"]
